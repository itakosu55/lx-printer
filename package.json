{
  "name": "lx-printer",
  "version": "0.1.0",
  "description": "Print library for LX series thermal printers",
  "type": "module",
  "exports": {
    "./lx-d02": {
      "types": "./dist/lx-d02.d.ts",
      "default": "./dist/lx-d02.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/lx-d02.ts --watch --dts",
    "build": "tsup src/lx-d02.ts --format esm --dts --clean",
    "lint": "eslint . && prettier . --check",
    "lint:fix": "prettier . --write && eslint . --fix",
    "type-check": "tsc --noEmit",
    "demo": "vite demo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "lx-d02",
    "thermal-printer",
    "web-bluetooth",
    "bluetooth"
  ],
  "author": "itakosu55",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/web-bluetooth": "^0.0.20",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.2",
    "prettier": "3.8.3",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itakosu55/lx-printer.git"
  },
  "homepage": "https://github.com/itakosu55/lx-printer",
  "bugs": {
    "url": "https://github.com/itakosu55/lx-printer/issues"
  }
}
